# =================================================
# BYBIT P2P BOT LATAM - Archivo de configuracion
# Copia este archivo como .env y completa los valores
# NUNCA subas el archivo .env a GitHub
# =================================================

# ==================== BYBIT API ====================
# Obtener en: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=tu_api_key_aqui
BYBIT_API_SECRET=tu_api_secret_aqui

# Usar testnet para pruebas (true) o mainnet para produccion (false)
BYBIT_TESTNET=false

# ==================== TELEGRAM ====================
# 1. Crea un bot con @BotFather en Telegram
# 2. Obtén el token del bot
# 3. Obtén tu chat_id enviando un mensaje al bot y usando:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# ==================== INTERVALOS ====================
# Cada cuantos segundos verificar nuevas ordenes (default: 30)
CHECK_INTERVAL=30

# Cada cuantos segundos verificar actualizaciones de ordenes activas (default: 60)
UPDATE_INTERVAL=60

# Hora del reporte diario en formato HH:MM (default: 23:00)
REPORT_TIME=23:00

# ==================== CONFIGURACION REGIONAL ====================
# Moneda fiat de tu region:
# VES = Venezuela (Bolivar)
# COP = Colombia (Peso)
# ARS = Argentina (Peso)
# PEN = Peru (Sol)
# CLP = Chile (Peso)
# MXN = Mexico (Peso)
FIAT_CURRENCY=VES

# Zona horaria
# America/Caracas, America/Bogota, America/Lima, etc.
TIMEZONE=America/Caracas

# ==================== LIMITES Y ALERTAS ====================
# Monto minimo en USDT para recibir alertas (0 = todas las ordenes)
MIN_ALERT_AMOUNT=0

# Maximo de ordenes activas simultaneas antes de alerta especial
MAX_ACTIVE_ORDERS=10
